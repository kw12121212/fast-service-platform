{
  "schemaVersion": "fsp-derived-app-template-map/v1",
  "contractVersion": "fsp-structured-app-template-contract/v1",
  "mapId": "default-derived-app-template-map",
  "entries": [
    {
      "id": "generated-readme",
      "matchKind": "exact",
      "path": "README.md",
      "unitType": "customization-zone",
      "ownership": "derived-managed",
      "upgradeBehavior": "preserve-by-default",
      "description": "The generated root README may be adapted for the derived application."
    },
    {
      "id": "generated-agents-guide",
      "matchKind": "exact",
      "path": "AGENTS.md",
      "unitType": "stable-template",
      "ownership": "platform-managed",
      "upgradeBehavior": "refresh-from-platform",
      "description": "The generated AGENTS entrypoint stays aligned with the repository-owned workflow."
    },
    {
      "id": "generated-context",
      "matchKind": "exact",
      "path": "docs/ai/context.json",
      "unitType": "stable-template",
      "ownership": "platform-managed",
      "upgradeBehavior": "refresh-from-platform",
      "description": "Generated AI context mirrors the repository-owned contract and selected module set."
    },
    {
      "id": "generated-lifecycle",
      "matchKind": "exact",
      "path": "docs/ai/derived-app-lifecycle.json",
      "unitType": "stable-template",
      "ownership": "platform-managed",
      "upgradeBehavior": "refresh-from-platform",
      "description": "Lifecycle metadata must stay aligned with the source platform release and selected modules."
    },
    {
      "id": "template-contract-asset",
      "matchKind": "exact",
      "path": "docs/ai/structured-app-template-contract.json",
      "unitType": "stable-template",
      "ownership": "platform-managed",
      "upgradeBehavior": "refresh-from-platform",
      "description": "The structured template contract is copied into generated applications as a normative asset."
    },
    {
      "id": "template-map-asset",
      "matchKind": "exact",
      "path": "docs/ai/template-classifications/default-derived-app-template-map.json",
      "unitType": "stable-template",
      "ownership": "platform-managed",
      "upgradeBehavior": "refresh-from-platform",
      "description": "The default classification map explains platform-managed and derived-managed output areas."
    },
    {
      "id": "frontend-admin-routes",
      "matchKind": "exact",
      "path": "frontend/src/app/router.tsx",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "slotId": "frontend-admin-routes",
      "upgradeBehavior": "refresh-slot-host-with-review-for-local-edits",
      "description": "Selected modules contribute route fragments through the repository-defined route slot."
    },
    {
      "id": "frontend-admin-navigation",
      "matchKind": "exact",
      "path": "frontend/src/app/navigation.ts",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "slotId": "frontend-admin-navigation",
      "upgradeBehavior": "refresh-slot-host-with-review-for-local-edits",
      "description": "Selected modules contribute navigation fragments through the repository-defined navigation slot."
    },
    {
      "id": "backend-table-contract",
      "matchKind": "exact",
      "path": "backend/src/main/resources/sql/tables.sql",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "slotId": "backend-table-contract",
      "upgradeBehavior": "refresh-slot-host-with-review-for-local-edits",
      "description": "Selected modules contribute SQL table fragments through the repository-defined table slot."
    },
    {
      "id": "backend-service-contract",
      "matchKind": "exact",
      "path": "backend/src/main/resources/sql/services.sql",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "slotId": "backend-service-contract",
      "upgradeBehavior": "refresh-slot-host-with-review-for-local-edits",
      "description": "Selected modules contribute SQL service fragments through the repository-defined service slot."
    },
    {
      "id": "backend-demo-data",
      "matchKind": "exact",
      "path": "backend/src/main/resources/sql/demo.sql",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "slotId": "backend-demo-data",
      "upgradeBehavior": "refresh-slot-host-with-review-for-local-edits",
      "description": "Selected modules contribute demo-data fragments through the repository-defined demo-data slot."
    },
    {
      "id": "project-management-page-fragment",
      "matchKind": "exact",
      "path": "frontend/src/features/projects/projects-page.tsx",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "project-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The projects page is emitted when project management is selected."
    },
    {
      "id": "project-management-service-fragment",
      "matchKind": "exact",
      "path": "backend/src/main/java/com/fastservice/platform/backend/project/ProjectServiceImpl.java",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "project-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The project service implementation is emitted when project management is selected."
    },
    {
      "id": "frontend-derived-customizations",
      "matchKind": "prefix",
      "path": "frontend/src/features/custom/",
      "unitType": "customization-zone",
      "ownership": "derived-managed",
      "upgradeBehavior": "preserve-by-default",
      "pathMayBeAbsentUntilCustomized": true,
      "description": "Preferred derived-app-owned frontend customization zone."
    },
    {
      "id": "backend-derived-customizations",
      "matchKind": "prefix",
      "path": "backend/src/main/java/com/fastservice/platform/backend/custom/",
      "unitType": "customization-zone",
      "ownership": "derived-managed",
      "upgradeBehavior": "preserve-by-default",
      "pathMayBeAbsentUntilCustomized": true,
      "description": "Preferred derived-app-owned backend customization zone."
    },
    {
      "id": "admin-shell-layout-fragment",
      "matchKind": "exact",
      "path": "frontend/src/app/admin-shell.tsx",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "admin-shell",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The admin shell layout is contributed by the admin-shell module."
    },
    {
      "id": "admin-shell-dashboard-fragment",
      "matchKind": "exact",
      "path": "frontend/src/features/dashboard/dashboard-page.tsx",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "admin-shell",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The dashboard entry page is contributed by the admin-shell module."
    },
    {
      "id": "user-management-page-fragment",
      "matchKind": "exact",
      "path": "frontend/src/features/users/users-page.tsx",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "user-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The users page is emitted when user management is selected."
    },
    {
      "id": "user-management-service-fragment",
      "matchKind": "exact",
      "path": "backend/src/main/java/com/fastservice/platform/backend/user/UserServiceImpl.java",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "user-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The user service implementation is emitted when user management is selected."
    },
    {
      "id": "role-permission-management-page-fragment",
      "matchKind": "exact",
      "path": "frontend/src/features/roles/role-permissions-page.tsx",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "role-permission-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The role-permissions page is emitted when role-permission management is selected."
    },
    {
      "id": "role-permission-management-service-fragment",
      "matchKind": "exact",
      "path": "backend/src/main/java/com/fastservice/platform/backend/access/AccessControlServiceImpl.java",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "role-permission-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The access control service implementation is emitted when role-permission management is selected."
    },
    {
      "id": "kanban-management-page-fragment",
      "matchKind": "exact",
      "path": "frontend/src/features/kanban/kanban-page.tsx",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "kanban-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The kanban page is emitted when kanban management is selected."
    },
    {
      "id": "kanban-management-service-fragment",
      "matchKind": "exact",
      "path": "backend/src/main/java/com/fastservice/platform/backend/kanban/KanbanServiceImpl.java",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "kanban-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The kanban service implementation is emitted when kanban management is selected."
    },
    {
      "id": "ticket-management-page-fragment",
      "matchKind": "exact",
      "path": "frontend/src/features/tickets/tickets-page.tsx",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "ticket-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The tickets page is emitted when ticket management is selected."
    },
    {
      "id": "ticket-management-service-fragment",
      "matchKind": "exact",
      "path": "backend/src/main/java/com/fastservice/platform/backend/ticket/TicketServiceImpl.java",
      "unitType": "module-fragment",
      "ownership": "module-managed",
      "moduleId": "ticket-management",
      "upgradeBehavior": "review-before-overwrite",
      "description": "The ticket service implementation is emitted when ticket management is selected."
    },
    {
      "id": "module-selection-config",
      "matchKind": "exact",
      "path": "frontend/src/app/module-selection.ts",
      "unitType": "customization-zone",
      "ownership": "derived-managed",
      "upgradeBehavior": "preserve-by-default",
      "description": "The module-selection configuration is the derived-app-owned entry point for choosing the active module profile."
    }
  ]
}
