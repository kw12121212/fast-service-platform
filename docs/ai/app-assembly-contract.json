{
  "schemaVersion": "fsp-app-assembly-contract/v2",
  "manifestSchemaVersion": "fsp-app-manifest/v1",
  "requiredManifestFields": [
    "schemaVersion",
    "application.id",
    "application.name",
    "application.packagePrefix",
    "modules"
  ],
  "normativeAssets": {
    "assemblyContract": "docs/ai/app-assembly-contract.json",
    "manifestSchema": "docs/ai/schemas/app-manifest.schema.json",
    "moduleRegistry": "docs/ai/module-registry.json",
    "moduleRegistrySchema": "docs/ai/schemas/module-registry.schema.json",
    "generatedAppVerificationContract": "docs/ai/generated-app-verification-contract.json",
    "generatedAppVerificationContractSchema": "docs/ai/schemas/generated-app-verification-contract.schema.json",
    "compatibilitySuite": "docs/ai/compatibility/app-assembly-suite.json",
    "compatibilitySuiteSchema": "docs/ai/schemas/app-assembly-compatibility-suite.schema.json"
  },
  "outputRules": {
    "mustBeOutsideRepositoryWorkspace": true,
    "applicationShape": "monolith",
    "scope": "enterprise-internal-management"
  },
  "outputInvariants": {
    "requiredFiles": [
      "README.md",
      "AGENTS.md",
      "app-manifest.json",
      "docs/ai/context.json",
      "docs/ai/module-registry.json",
      "docs/ai/app-assembly-contract.json",
      "docs/ai/generated-app-verification-contract.json",
      "docs/ai/compatibility/app-assembly-suite.json",
      "docs/ai/compatibility/fixtures/missing-required-core.manifest.json",
      "docs/ai/compatibility/fixtures/unknown-module.manifest.json",
      "docs/ai/compatibility/fixtures/missing-dependency.manifest.json",
      "docs/ai/schemas/app-manifest.schema.json",
      "docs/ai/schemas/module-registry.schema.json",
      "docs/ai/schemas/generated-app-verification-contract.schema.json",
      "docs/ai/schemas/app-assembly-compatibility-suite.schema.json",
      "backend/pom.xml",
      "frontend/package.json",
      "scripts/app-assembly-lib.mjs",
      "scripts/verify-derived-app.mjs",
      "scripts/verify-derived-app.sh"
    ],
    "moduleWiringSources": {
      "frontendRoutes": "module-registry.modules[].frontend.routes",
      "backendServices": "module-registry.modules[].backend.services",
      "backendTables": "module-registry.modules[].backend.tables"
    }
  },
  "machineReadableIndexes": {
    "repositoryEntry": [
      "docs/ai/quickstart.md",
      "docs/ai/context.yaml"
    ],
    "moduleRegistry": "docs/ai/module-registry.json",
    "schemas": [
      "docs/ai/schemas/app-manifest.schema.json",
      "docs/ai/schemas/module-registry.schema.json",
      "docs/ai/schemas/generated-app-verification-contract.schema.json",
      "docs/ai/schemas/app-assembly-compatibility-suite.schema.json"
    ],
    "generatedAppVerificationContract": "docs/ai/generated-app-verification-contract.json",
    "compatibilitySuite": "docs/ai/compatibility/app-assembly-suite.json",
    "assemblyExamples": [
      "docs/ai/manifests/default-baseline-app.json",
      "docs/ai/manifests/core-admin-app.json"
    ]
  },
  "referenceImplementations": [
    {
      "id": "node-scaffolder",
      "type": "reference-implementation",
      "language": "node-esm",
      "scaffoldEntrypoint": "scripts/scaffold-derived-app.mjs",
      "generatedAppVerifier": "scripts/verify-derived-app.mjs",
      "generatedAppVerifierRole": "reference-verifier"
    },
    {
      "id": "java-cli",
      "type": "compatible-implementation",
      "language": "java-cli",
      "workspace": "tools/java-assembly-cli",
      "mainClass": "com.fastservice.platform.tools.assemblycli.AppAssemblyCli",
      "scaffoldEntrypoint": "scripts/scaffold-derived-app-java.sh",
      "generatedAppVerifier": "scripts/verify-derived-app-java.sh",
      "generatedAppVerifierRole": "compatible-verifier"
    }
  ],
  "commands": {
    "scaffold": {
      "node": "node scripts/scaffold-derived-app.mjs --manifest <manifest-path> --output <absolute-output-dir>",
      "java": "./scripts/scaffold-derived-app-java.sh <manifest-path> <absolute-output-dir>"
    },
    "verifyCompatibility": "node scripts/verify-app-assembly-compatibility.mjs",
    "verifyRepositoryAssembly": "./scripts/verify-app-assembly.sh",
    "referenceVerifyGeneratedApp": "node scripts/verify-derived-app.mjs <generated-app-dir>",
    "verifyGeneratedApp": "./scripts/verify-derived-app.sh <generated-app-dir>",
    "verifyGeneratedAppJava": "./scripts/verify-derived-app-java.sh <generated-app-dir>"
  }
}
