{
  "schemaVersion": "fsp-management-module-descriptor/v1",
  "source": {
    "planningInput": {
      "sourceAsset": "docs/ai/solution-plans/core-admin-console.solution-to-manifest-plan.json",
      "schemaVersion": "fsp-solution-to-manifest-plan/v1"
    },
    "recommendationInput": {
      "sourceAsset": "docs/ai/solution-recommendations/core-admin-console.solution-to-manifest-recommendation.json",
      "schemaVersion": "fsp-solution-to-manifest-recommendation/v1"
    }
  },
  "application": {
    "name": "Core Admin Console",
    "manifestId": "core-admin-console",
    "packagePrefix": "com.fastservice.platform.derived"
  },
  "managementModule": {
    "moduleId": "leave-request",
    "displayName": "Leave Request",
    "routePath": "/leave-requests",
    "primaryEntity": "LeaveRequest",
    "summary": "A workflow-enabled management module for leave request submission, approval, and tracking with report, form, and workflow views.",
    "report": {
      "componentId": "dynamic-report",
      "title": "Leave Requests",
      "columns": [
        {
          "id": "requestId",
          "label": "Request ID"
        },
        {
          "id": "employeeName",
          "label": "Employee"
        },
        {
          "id": "leaveType",
          "label": "Leave Type"
        },
        {
          "id": "startDate",
          "label": "Start Date"
        },
        {
          "id": "endDate",
          "label": "End Date"
        },
        {
          "id": "status",
          "label": "Status"
        }
      ]
    },
    "form": {
      "componentId": "dynamic-form",
      "title": "Leave Request",
      "submitLabel": "Submit Request",
      "fields": [
        {
          "id": "leaveType",
          "label": "Leave Type",
          "type": "select",
          "required": true
        },
        {
          "id": "startDate",
          "label": "Start Date",
          "type": "date",
          "required": true
        },
        {
          "id": "endDate",
          "label": "End Date",
          "type": "date",
          "required": true
        },
        {
          "id": "reason",
          "label": "Reason",
          "type": "textarea",
          "required": false
        }
      ]
    },
    "workflow": {
      "componentId": "workflow-panel",
      "entityName": "LeaveRequest",
      "stateLabel": "Status",
      "assigneeLabel": "Assignee",
      "commentLabel": "Comment",
      "commentPlaceholder": "Add a comment about this action...",
      "historyTitle": "Workflow History",
      "actions": [
        {
          "action": "submit",
          "label": "Submit"
        },
        {
          "action": "approve",
          "label": "Approve"
        },
        {
          "action": "reject",
          "label": "Reject"
        },
        {
          "action": "reassign",
          "label": "Reassign",
          "requiresAssignee": true
        }
      ],
      "backendWorkflowService": {
        "workflowServiceName": "leave_request_workflow_service",
        "ddlReference": "backend/src/main/resources/sql/workflows/leave-request.sql"
      }
    }
  },
  "manifestPreparation": {
    "standaloneManifestRequired": true,
    "selectedPlatformModules": [
      "admin-shell",
      "user-management",
      "role-permission-management"
    ],
    "profileAlignment": "core-admin",
    "nextStep": "Keep the core-admin standalone app-manifest as the assembly runtime input, then pass the descriptor-derived module inputs through repository-owned template boundaries."
  },
  "generatedModuleInputs": {
    "frontend": {
      "reportComponentId": "dynamic-report",
      "formComponentId": "dynamic-form",
      "workflowComponentId": "workflow-panel",
      "featurePath": "frontend/src/features/custom/leave-request/"
    },
    "backend": {
      "serviceContractId": "leave_request_service",
      "tableName": "leave_request_record",
      "implementationPath": "backend/src/main/java/com/fastservice/platform/backend/custom/leave-request/"
    }
  },
  "templateBindings": [
    {
      "slotId": "frontend-admin-routes",
      "path": "frontend/src/app/router.tsx",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "notes": "The descriptor contributes a bounded route entry through the existing admin route slot."
    },
    {
      "slotId": "frontend-admin-navigation",
      "path": "frontend/src/app/navigation.ts",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "notes": "The descriptor contributes a navigation item through the existing admin navigation slot."
    },
    {
      "slotId": "frontend-customization-zone",
      "path": "frontend/src/features/custom/leave-request/",
      "unitType": "customization-zone",
      "ownership": "derived-managed",
      "notes": "Generated report, form, and workflow descriptors stay inside the existing derived-managed frontend customization zone."
    },
    {
      "slotId": "backend-table-contract",
      "path": "backend/src/main/resources/sql/tables.sql",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "notes": "The descriptor contributes SQL table fragments through the repository-owned backend table slot."
    },
    {
      "slotId": "backend-service-contract",
      "path": "backend/src/main/resources/sql/services.sql",
      "unitType": "slot-host",
      "ownership": "platform-managed",
      "notes": "The descriptor contributes SQL service fragments through the repository-owned backend service slot."
    },
    {
      "slotId": "backend-customization-zone",
      "path": "backend/src/main/java/com/fastservice/platform/backend/custom/leave-request/",
      "unitType": "customization-zone",
      "ownership": "derived-managed",
      "notes": "Generated Java implementation details stay inside the existing backend customization zone."
    }
  ],
  "boundaries": {
    "usesWorkflowGeneration": true,
    "extendsClosedModuleRegistry": false,
    "descriptorIsAssemblyRuntimeInput": false
  }
}
