{
  "schemaVersion": "fsp-ai-solution-input-contract/v1",
  "normativeAssets": {
    "solutionInputSchema": "docs/ai/schemas/ai-solution-input.schema.json",
    "solutionToManifestPlanningContract": "docs/ai/solution-to-manifest-planning-contract.json",
    "solutionToManifestPlanningSchema": "docs/ai/schemas/solution-to-manifest-planning.schema.json",
    "solutionToManifestRecommendationContract": "docs/ai/solution-to-manifest-recommendation-contract.json",
    "solutionToManifestRecommendationSchema": "docs/ai/schemas/solution-to-manifest-recommendation.schema.json",
    "descriptorDrivenManagementModuleContract": "docs/ai/descriptor-driven-management-module-contract.json",
    "descriptorDrivenManagementModuleSchema": "docs/ai/schemas/descriptor-driven-management-module.schema.json",
    "aiToolOrchestrationContract": "docs/ai/ai-tool-orchestration-contract.json",
    "appAssemblyContract": "docs/ai/app-assembly-contract.json",
    "moduleRegistry": "docs/ai/module-registry.json"
  },
  "requiredFields": [
    "schemaVersion",
    "application.name",
    "application.summary",
    "application.domain",
    "application.targetShape",
    "roles",
    "workflows"
  ],
  "optionalFields": [
    "application.idHint",
    "application.packagePrefixHint",
    "domainObjects",
    "uiReferences.prototypeImages",
    "uiReferences.referenceSites",
    "constraints.requiredModules",
    "constraints.excludedModules",
    "constraints.notes"
  ],
  "inputLayering": {
    "solutionInputRole": "capture-business-intent-before-assembly",
    "planningRole": "produce-deterministic-module-and-manifest-preparation-decisions-before-assembly",
    "recommendationRole": "optionally-produce-manifest-guidance-after-planning-before-assembly",
    "descriptorRole": "optionally-produce-bounded-management-module-generation-facts-before-assembly",
    "assemblyManifestRole": "direct-input-to-repository-owned-assembly-tooling",
    "mappingBoundary": "solution input MUST be translated into app-manifest before repository-owned assembly tooling is invoked"
  },
  "mappingGuidance": {
    "applicationIdentity": {
      "idHint": "application.idHint MAY be used to derive app-manifest.application.id; if omitted, the contributor MUST produce a valid manifest id before assembly",
      "packagePrefixHint": "application.packagePrefixHint MAY be used to derive app-manifest.application.packagePrefix; if omitted, the contributor MUST produce a valid Java package prefix before assembly"
    },
    "moduleSelectionSources": [
      "constraints.requiredModules",
      "constraints.excludedModules",
      "application.summary",
      "roles",
      "domainObjects",
      "workflows"
    ],
    "planningContract": "docs/ai/solution-to-manifest-planning-contract.json",
    "recommendationContract": "docs/ai/solution-to-manifest-recommendation-contract.json",
    "descriptorContract": "docs/ai/descriptor-driven-management-module-contract.json",
    "uiReferenceBoundary": "uiReferences inform UI direction and interaction expectations but do not bypass manifest-driven module selection"
  },
  "aiToolingGuidance": {
    "defaultRole": "tool-orchestrator",
    "playbook": "docs/ai/playbooks/define-ai-solution-input.md",
    "nextStep": "produce a solution-to-manifest plan, optionally review or create a solution-to-manifest recommendation, optionally prepare a bounded management-module descriptor, and then produce a standalone app-manifest before invoking ./scripts/platform-tool.sh assembly scaffold"
  },
  "examplePlans": [
    "docs/ai/solution-plans/core-admin-console.solution-to-manifest-plan.json"
  ],
  "exampleRecommendations": [
    "docs/ai/solution-recommendations/core-admin-console.solution-to-manifest-recommendation.json"
  ],
  "exampleDescriptors": [
    "docs/ai/management-modules/department-directory.management-module.json"
  ],
  "exampleInputs": [
    "docs/ai/solution-inputs/core-admin-console.solution-input.json"
  ]
}
