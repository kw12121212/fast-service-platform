{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastservice.local/docs/ai/schemas/platform-release-advisory.schema.json",
  "title": "Fast Service Platform Release Advisory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "previousRelease",
    "currentRelease",
    "overallCompatibilityPosture",
    "summary",
    "changes",
    "recommendedNextActions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "fsp-platform-release-advisory/v1"
    },
    "previousRelease": {
      "$ref": "#/$defs/releaseRef"
    },
    "currentRelease": {
      "$ref": "#/$defs/releaseRef"
    },
    "overallCompatibilityPosture": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change"
      },
      "minItems": 1
    },
    "recommendedNextActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "releaseRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "releaseId",
        "version"
      ],
      "properties": {
        "releaseId": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "changeType",
        "compatibility",
        "summary",
        "impactedAssets",
        "impactedModules",
        "recommendedChecks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "changeType": {
          "type": "string",
          "minLength": 1
        },
        "compatibility": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "impactedAssets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "impactedModules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "recommendedChecks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
