{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastservice.local/docs/ai/schemas/solution-to-manifest-planning.schema.json",
  "title": "Fast Service Platform Solution To Manifest Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "solutionInput",
    "application",
    "modulePlanning",
    "manifestPreparation"
  ],
  "properties": {
    "schemaVersion": {
      "const": "fsp-solution-to-manifest-plan/v1"
    },
    "solutionInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceAsset",
        "schemaVersion"
      ],
      "properties": {
        "sourceAsset": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "const": "fsp-ai-solution-input/v1"
        }
      }
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "manifestId",
        "packagePrefix"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "manifestId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "packagePrefix": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        }
      }
    },
    "modulePlanning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "includedModules",
        "excludedModules",
        "decisions"
      ],
      "properties": {
        "includedModules": {
          "$ref": "#/$defs/moduleIdList"
        },
        "excludedModules": {
          "$ref": "#/$defs/moduleIdList"
        },
        "decisions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/moduleDecision"
          }
        }
      }
    },
    "manifestPreparation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standaloneManifestRequired",
        "resolvedFields",
        "unresolvedFields",
        "conflicts",
        "nextStep"
      ],
      "properties": {
        "standaloneManifestRequired": {
          "const": true
        },
        "resolvedFields": {
          "$ref": "#/$defs/stringList"
        },
        "unresolvedFields": {
          "$ref": "#/$defs/stringList"
        },
        "conflicts": {
          "$ref": "#/$defs/stringList"
        },
        "nextStep": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "moduleIdList": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisionBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "reference",
        "summary"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "reference": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "moduleDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "moduleId",
        "disposition",
        "basis"
      ],
      "properties": {
        "moduleId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "disposition": {
          "enum": [
            "include",
            "exclude"
          ]
        },
        "basis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/decisionBasis"
          }
        }
      }
    }
  }
}
