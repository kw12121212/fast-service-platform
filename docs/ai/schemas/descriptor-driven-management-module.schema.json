{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastservice.local/docs/ai/schemas/descriptor-driven-management-module.schema.json",
  "title": "Fast Service Platform Descriptor-Driven Management Module",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "source",
    "application",
    "managementModule",
    "manifestPreparation",
    "generatedModuleInputs",
    "templateBindings",
    "boundaries"
  ],
  "properties": {
    "schemaVersion": {
      "const": "fsp-management-module-descriptor/v1"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planningInput"
      ],
      "properties": {
        "planningInput": {
          "$ref": "#/$defs/sourceReference"
        },
        "recommendationInput": {
          "$ref": "#/$defs/sourceReference"
        }
      }
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "manifestId",
        "packagePrefix"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "manifestId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "packagePrefix": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        }
      }
    },
    "managementModule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "moduleId",
        "displayName",
        "routePath",
        "primaryEntity",
        "report",
        "form"
      ],
      "properties": {
        "moduleId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "routePath": {
          "type": "string",
          "pattern": "^/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "primaryEntity": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "report": {
          "$ref": "#/$defs/reportDescriptor"
        },
        "form": {
          "$ref": "#/$defs/formDescriptor"
        }
      }
    },
    "manifestPreparation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standaloneManifestRequired",
        "selectedPlatformModules",
        "profileAlignment",
        "nextStep"
      ],
      "properties": {
        "standaloneManifestRequired": {
          "const": true
        },
        "selectedPlatformModules": {
          "$ref": "#/$defs/moduleIdList"
        },
        "profileAlignment": {
          "type": "string",
          "minLength": 1
        },
        "nextStep": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "generatedModuleInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frontend",
        "backend"
      ],
      "properties": {
        "frontend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reportComponentId",
            "formComponentId",
            "featurePath"
          ],
          "properties": {
            "reportComponentId": {
              "const": "dynamic-report"
            },
            "formComponentId": {
              "const": "dynamic-form"
            },
            "featurePath": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "backend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "serviceContractId",
            "tableName",
            "implementationPath"
          ],
          "properties": {
            "serviceContractId": {
              "type": "string",
              "pattern": "^[a-z0-9_]+$"
            },
            "tableName": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            },
            "implementationPath": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "templateBindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/templateBinding"
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "usesWorkflowGeneration",
        "extendsClosedModuleRegistry",
        "descriptorIsAssemblyRuntimeInput"
      ],
      "properties": {
        "usesWorkflowGeneration": {
          "const": false
        },
        "extendsClosedModuleRegistry": {
          "const": false
        },
        "descriptorIsAssemblyRuntimeInput": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceAsset",
        "schemaVersion"
      ],
      "properties": {
        "sourceAsset": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "moduleIdList": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "reportColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-zA-Z0-9]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reportDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "componentId",
        "title",
        "columns"
      ],
      "properties": {
        "componentId": {
          "const": "dynamic-report"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/reportColumn"
          }
        }
      }
    },
    "formField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "type",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-zA-Z0-9]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "text",
            "textarea",
            "select",
            "number",
            "checkbox",
            "date"
          ]
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "formDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "componentId",
        "title",
        "submitLabel",
        "fields"
      ],
      "properties": {
        "componentId": {
          "const": "dynamic-form"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "submitLabel": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/formField"
          }
        }
      }
    },
    "templateBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slotId",
        "path",
        "unitType",
        "ownership"
      ],
      "properties": {
        "slotId": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "unitType": {
          "enum": [
            "slot-host",
            "module-fragment",
            "customization-zone"
          ]
        },
        "ownership": {
          "enum": [
            "platform-managed",
            "module-managed",
            "derived-managed"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
