{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastservice.local/docs/ai/schemas/app-manifest.schema.json",
  "title": "Fast Service Platform App Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "application",
    "modules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "fsp-app-manifest/v1"
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "packagePrefix"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "packagePrefix": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        }
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
