{
  "schemaVersion": "fsp-derived-app-lifecycle-contract/v1",
  "normativeAssets": {
    "lifecycleContract": "docs/ai/derived-app-lifecycle-contract.json",
    "lifecycleContractSchema": "docs/ai/schemas/derived-app-lifecycle-contract.schema.json",
    "lifecycleMetadataSchema": "docs/ai/schemas/derived-app-lifecycle-metadata.schema.json",
    "upgradeExecutionContract": "docs/ai/derived-app-upgrade-execution-contract.json",
    "upgradeExecutionContractSchema": "docs/ai/schemas/derived-app-upgrade-execution-contract.schema.json",
    "platformReleaseMetadata": "docs/ai/platform-release.json",
    "platformReleaseHistory": "docs/ai/platform-release-history.json",
    "platformReleaseHistorySchema": "docs/ai/schemas/platform-release-history.schema.json",
    "platformReleaseAdvisory": "docs/ai/platform-release-advisory.json",
    "platformReleaseAdvisorySchema": "docs/ai/schemas/platform-release-advisory.schema.json",
    "moduleRegistry": "docs/ai/module-registry.json"
  },
  "generatedOutput": {
    "lifecycleMetadata": "docs/ai/derived-app-lifecycle.json",
    "generatedContext": "docs/ai/context.json",
    "applicationManifest": "app-manifest.json"
  },
  "requiredLifecycleFields": [
    "schemaVersion",
    "contractVersion",
    "application.id",
    "application.name",
    "application.packagePrefix",
    "sourcePlatform.id",
    "sourcePlatform.name",
    "sourcePlatform.releaseId",
    "sourcePlatform.version",
    "sourcePlatform.assemblyContractVersion",
    "sourcePlatform.generatedAppVerificationContractVersion",
    "selectedModules",
    "requiredCoreModules",
    "upgradeEvaluation.repositoryOwnedEntrypoint",
    "upgradeEvaluation.repositoryOwnedTargetSelectionEntrypoint",
    "upgradeEvaluation.repositoryOwnedAdvisoryEntrypoint",
    "upgradeEvaluation.repositoryOwnedExecutionEntrypoint",
    "upgradeEvaluation.platformReleaseMetadata",
    "upgradeEvaluation.platformReleaseHistory",
    "upgradeEvaluation.platformReleaseAdvisory",
    "upgradeEvaluation.upgradeExecutionContract"
  ],
  "upgradeEvaluation": {
    "repositoryOwnedEntrypoint": "./scripts/evaluate-derived-app-upgrade.sh <generated-app-dir>",
    "repositoryOwnedTargetSelectionEntrypoint": "./scripts/list-platform-upgrade-targets.sh [generated-app-dir]",
    "repositoryOwnedAdvisoryEntrypoint": "./scripts/show-platform-release-advisory.sh [generated-app-dir]",
    "repositoryOwnedExecutionEntrypoint": "./scripts/execute-derived-app-upgrade.sh <generated-app-dir> [--apply]",
    "requiredGeneratedInputs": [
      "app-manifest.json",
      "docs/ai/context.json",
      "docs/ai/derived-app-lifecycle.json"
    ],
    "compatibilitySignals": [
      "matching-source-platform-id",
      "recognized-source-platform-release",
      "supported-upgrade-path-to-target-release",
      "supported-lifecycle-metadata-version",
      "supported-lifecycle-contract-version",
      "supported-assembly-contract-version",
      "selected-modules-known-to-target-platform"
    ],
    "resultShape": {
      "compatible": "boolean",
      "issues": "string[]",
      "sourcePlatformRelease": "string",
      "targetPlatformRelease": "string",
      "recommendedAction": "string"
    }
  }
}
