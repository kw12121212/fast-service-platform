{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastservice.local/docs/ai/schemas/ai-solution-input.schema.json",
  "title": "Fast Service Platform AI Solution Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "application",
    "roles",
    "workflows"
  ],
  "properties": {
    "schemaVersion": {
      "const": "fsp-ai-solution-input/v1"
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "summary",
        "domain",
        "targetShape"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "const": "enterprise-internal-management"
        },
        "targetShape": {
          "const": "monolith"
        },
        "idHint": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "packagePrefixHint": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/namedSummaryItem"
      }
    },
    "domainObjects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/namedSummaryItem"
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/namedSummaryItem"
      }
    },
    "uiReferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prototypeImages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "referenceSites": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiredModules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "excludedModules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "namedSummaryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
